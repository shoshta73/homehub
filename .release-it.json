{
  "git": {
    "commit": false,
    "tag": false,
    "push": false
  },
  "github": {
    "release": false
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "infile": "docs/changes.md",
      "preset": {
        "name": "conventionalcommits",
        "types": [
          {
            "type": "breaking",
            "section": "Breaking Changes"
          },
          {
            "type": "feat",
            "section": "Features"
          },
          {
            "type": "fix",
            "section": "Bug Fixes"
          },
          {
            "type": "perf",
            "section": "Performance Improvements"
          },
          {
            "type": "revert",
            "section": "Reverts"
          },
          {
            "type": "docs",
            "section": "Documentation"
          },
          {
            "type": "style",
            "section": "Styles"
          },
          {
            "type": "chore",
            "section": "Miscellaneous Chores"
          },
          {
            "type": "refactor",
            "section": "Code Refactoring"
          },
          {
            "type": "test",
            "section": "Tests"
          },
          {
            "type": "build",
            "section": "Build System"
          },
          {
            "type": "ci",
            "section": "CI - CD"
          }
        ]
      }
    }
  }
}
